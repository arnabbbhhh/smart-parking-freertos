/**
  * @brief  The application entry point.
  * @retval int
  */
int main(void)
{
  /* MCU Configuration--------------------------------------------------------*/
  HAL_Init();
  SystemClock_Config();

  /* Initialize all configured peripherals */
  MX_GPIO_Init();
  MX_TIM4_Init();
  MX_USART2_UART_Init();

  /* USER CODE BEGIN 2 */
  // Create queues BEFORE kernel initialization
  parkingQueue = xQueueCreate(5, sizeof(uint8_t));
  servoQueue = xQueueCreate(5, sizeof(uint16_t) * 2);  // Store both servo positions
  uartMutex = xSemaphoreCreateMutex();

  // Verify queue and mutex creation
  if(parkingQueue == NULL || servoQueue == NULL || uartMutex == NULL)
  {
      printf("Failed to create queues/mutex!\r\n");
      Error_Handler();
  }

  // Start PWM channels for 2 SG90 servos
  HAL_TIM_PWM_Start(&htim4, TIM_CHANNEL_1);  // PB6
  HAL_TIM_PWM_Start(&htim4, TIM_CHANNEL_2);  // PB7

  // Set initial servo position (90° center)
  __HAL_TIM_SET_COMPARE(&htim4, TIM_CHANNEL_1, 1500);
  __HAL_TIM_SET_COMPARE(&htim4, TIM_CHANNEL_2, 1500);
  g_servo1_position = 1500;
  g_servo2_position = 1500;

  printf("\r\n");
  printf("===========================================\r\n");
  printf("   Smart Parking System Initialized\r\n");
  printf("===========================================\r\n");
  printf("PWM Started - Servos Ready\r\n");
  printf("Servo 1: PB6 (TIM4_CH1)\r\n");
  printf("Servo 2: PB7 (TIM4_CH2)\r\n");
  printf("\r\n");
  printf(">>> ADD TO LIVE EXPRESSIONS WINDOW <<<\r\n");
  printf("g_sensor1_PA0     - Spot 1 (0=Car, 1=Free)\r\n");
  printf("g_sensor2_PA1     - Spot 2 (0=Car, 1=Free)\r\n");
  printf("g_sensor3_PA6     - Spot 3 (0=Car, 1=Free)\r\n");
  printf("g_sensor4_PA7     - Spot 4 (0=Car, 1=Free)\r\n");
  printf("g_all_sensors     - All sensors (binary)\r\n");
  printf("g_occupied_spots  - Cars detected count\r\n");
  printf("g_available_spots - Free spots count\r\n");
  printf("g_servo1_position - Servo 1 PWM (PB6)\r\n");
  printf("g_servo2_position - Servo 2 PWM (PB7)\r\n");
  printf("===========================================\r\n\r\n");

  /* Init scheduler */
  osKernelInitialize();

  /* Create the thread(s) */
  defaultTaskHandle = osThreadNew(StartDefaultTask, NULL, &defaultTask_attributes);
  irSensorTaskHandle = osThreadNew(IRSensorTask, NULL, &irSensorTask_attributes);
  gateServoTaskHandle = osThreadNew(GateServoTask, NULL, &gateServoTask_attributes);
  loggerTaskHandle = osThreadNew(LoggerTask, NULL, &loggerTask_attributes);

  // Verify task creation
  if(defaultTaskHandle == NULL || irSensorTaskHandle == NULL ||
     gateServoTaskHandle == NULL || loggerTaskHandle == NULL)
  {
      printf("Failed to create tasks!\r\n");
      Error_Handler();
  }

  printf("All tasks created successfully\r\n\r\n");

  /* Start scheduler */
  osKernelStart();

  /* We should never get here */
  while (1)
  {
  }
}

