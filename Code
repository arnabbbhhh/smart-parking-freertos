/* USER CODE BEGIN 4 */
void IRSensorTask(void *argument)
{
    uint8_t status;
    uint8_t prevStatus = 0xFF;

    printf("IRSensorTask started\r\n");

    while(1)
    {
        g_pin_PA0_raw = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_0);
        g_pin_PA1_raw = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_1);
        g_pin_PA6_raw = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_6);
        g_pin_PA7_raw = HAL_GPIO_ReadPin(GPIOA, GPIO_PIN_7);

        g_sensor1_PA0 = (uint8_t)g_pin_PA0_raw;
        g_sensor2_PA1 = (uint8_t)g_pin_PA1_raw;
        g_sensor3_PA6 = (uint8_t)g_pin_PA6_raw;
        g_sensor4_PA7 = (uint8_t)g_pin_PA7_raw;

        status  = g_sensor1_PA0 << 0;
        status |= g_sensor2_PA1 << 1;
        status |= g_sensor3_PA6 << 2;
        status |= g_sensor4_PA7 << 3;
        g_all_sensors = status;

        g_occupied_spots = g_sensor1_PA0 + g_sensor2_PA1 + g_sensor3_PA6 + g_sensor4_PA7;
        g_available_spots = 4 - g_occupied_spots;

        if(status != prevStatus)
        {
            xQueueSend(parkingQueue, &status, pdMS_TO_TICKS(10));
            prevStatus = status;
        }

        vTaskDelay(pdMS_TO_TICKS(100));
    }
}

void GateServoTask(void *argument)
{
    uint16_t servo_positions[2];

    printf("GateServoTask started\r\n");

    while(1)
    {
        if(xQueueReceive(servoQueue, &servo_positions, portMAX_DELAY) == pdPASS)
        {
            __HAL_TIM_SET_COMPARE(&htim4, TIM_CHANNEL_1, servo_positions[0]);
            __HAL_TIM_SET_COMPARE(&htim4, TIM_CHANNEL_2, servo_positions[1]);
            g_servo1_position = servo_positions[0];
            g_servo2_position = servo_positions[1];

            xSemaphoreTake(uartMutex, portMAX_DELAY);
            printf("Servos moved: Servo1=%d, Servo2=%d\r\n", servo_positions[0], servo_positions[1]);
            xSemaphoreGive(uartMutex);
        }
    }
}

void LoggerTask(void *argument)
{
    uint8_t data;
    uint8_t spot1, spot2, spot3, spot4;

    printf("LoggerTask started\r\n\r\n");

    while(1)
    {
        if(xQueueReceive(parkingQueue, &data, portMAX_DELAY) == pdPASS)
        {
            spot1 = (data >> 0) & 1;
            spot2 = (data >> 1) & 1;
            spot3 = (data >> 2) & 1;
            spot4 = (data >> 3) & 1;

            xSemaphoreTake(uartMutex, portMAX_DELAY);
            printf("===========================================\r\n");
            printf("        PARKING STATUS UPDATE\r\n");
            printf("===========================================\r\n");
            printf("Raw Data: 0x%02X (Binary: %d%d%d%d)\r\n", data, spot4, spot3, spot2, spot1);
            printf("-------------------------------------------\r\n");
            printf("Spot 1 (PA0): %s\r\n", spot1 ? "🚗 CAR DETECTED" : "✅ FREE");
            printf("Spot 2 (PA1): %s\r\n", spot2 ? "🚗 CAR DETECTED" : "✅ FREE");
            printf("Spot 3 (PA6): %s\r\n", spot3 ? "🚗 CAR DETECTED" : "✅ FREE");
            printf("Spot 4 (PA7): %s\r\n", spot4 ? "🚗 CAR DETECTED" : "✅ FREE");
            printf("-------------------------------------------\r\n");
            printf("Occupied Spots: %d/4\r\n", g_occupied_spots);
            printf("Available Spots: %d/4\r\n", g_available_spots);
            printf("Servo1: %d, Servo2: %d\r\n", g_servo1_position, g_servo2_position);
            printf("===========================================\r\n\r\n");
            xSemaphoreGive(uartMutex);
        }
    }
}

void StartDefaultTask(void *argument)
{
    printf("DefaultTask started\r\n");

    uint16_t servo_positions[2];
    uint16_t servo_open = 2000;
    uint16_t servo_close = 1000;

    while(1)
    {
        if(g_available_spots == 0)
        {
            servo_positions[0] = servo_close;
            servo_positions[1] = servo_close;
        }
        else if(g_available_spots == 4)
        {
            servo_positions[0] = servo_open;
            servo_positions[1] = servo_open;
        }
        else
        {
            servo_positions[0] = servo_open;
            servo_positions[1] = servo_open;
        }

        xQueueSend(servoQueue, &servo_positions, pdMS_TO_TICKS(10));
        osDelay(2000);
    }
}

